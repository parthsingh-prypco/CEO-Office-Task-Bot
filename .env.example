# Get these from api.slack.com/apps → your app → OAuth & Permissions / Basic Information
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# Slack List ID (the Project Tracker list in Cockpit canvas)
PROJECT_LIST_ID=F0B7RB480DA

# Slack channel to post notifications in (use channel ID, e.g. C0123456789)
NOTIFY_CHANNEL=C0123456789

# Upstash Redis — free at console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Random secret to protect your cron endpoints — generate any random string
CRON_SECRET=generate-a-random-string-here
